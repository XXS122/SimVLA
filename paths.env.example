# SimVLA 路径配置模板
# 复制此文件为 paths.env，填入本机实际路径，paths.env 不会被提交到 git
#
# 用法：
#   shell 脚本会自动 source 此文件
#   Python 脚本通过环境变量读取（也可手动 source 后运行）：
#     source paths.env && python train_smolvlm.py

# SmolVLM 预训练模型路径
SIMVLA_SMOLVLM_MODEL="/datasets/models/smolvlm/SmolVLM-500M-Instruct"

# VLABench 数据集路径（RLDS TFRecord 格式，包含 *.tfrecord-*-of-* 文件的目录）
SIMVLA_VLABENCH_DATA="/datasets/vlabench/data/1.0.0"


# VLABench 代码库路径（评估时需要）
SIMVLA_VLABENCH_CODE="/datasets/code/VLABench"

# 评估结果保存目录
SIMVLA_EVAL_RESULTS="/datasets/simvla_output/eval_results"

# LIBERO 数据集根目录（包含 libero_10/libero_goal/libero_object/libero_spatial 子目录）
# SIMVLA_LIBERO_DATA="/path/to/libero-datasets"

# GPU 配置（按本机实际显卡数量填写）
# 单卡示例：SIMVLA_CUDA_DEVICES=0  SIMVLA_NUM_GPUS=1
# 双卡示例：SIMVLA_CUDA_DEVICES=0,1  SIMVLA_NUM_GPUS=2
# 8卡示例：SIMVLA_CUDA_DEVICES=0,1,2,3,4,5,6,7  SIMVLA_NUM_GPUS=8
SIMVLA_CUDA_DEVICES="0,1"
SIMVLA_NUM_GPUS=2
